# Общие системные файлы
.DS_Store
Thumbs.db
*.log

# IDE и редакторы
.idea/
.vscode/
*.swp
*.swo

# Node.js зависимости
**/node_modules/

# Файлы сборки и кэша
**/dist/
**/.next/
**/out/
**/.cache/
**/.svelte-kit/

# Файлы окружения (секреты!)
.env
.env.local
.env.development
.env.test
.env.production

# Локальные настройки npm/yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Автогенерируемые файлы
*.pid
*.seed
*.pid.lock

# Файлы загрузок (если есть)
**/uploads/

# Для фронтенда (если используется Vite/React/Vue)
**/.eslintcache
**/coverage/
**/cypress/screenshots/
**/cypress/videos/

# Для бэкенда (Node.js)
**/package-lock.json  # если используете yarn
**/yarn.lock          # если используете npm
**/tmp/
**/temp/

# Динамические загрузки
backend/uploads/*
!backend/uploads/.gitkeep

frontend/public/assets/*
!frontend/public/assets/.gitkeep